{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "specify",
  "small_model": "openrouter/anthropic/claude-haiku-4.5",
  "model": "openai/gpt-5.4",
  "share": "disabled",
  "instructions": ["AGENTS.md"],
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": false
    },
    "implement": {}
  },
  "permission": {
    "lsp": "allow",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "grep *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "npm build *": "allow",
      "npm test *": "allow",
      "npm run lint *": "allow",
      "npm run typecheck *": "allow"
    }
  }
}
